      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    padding: 0;\n    overflow-x: hidden;\n  }\n\n  .hard-shadow {\n    box-shadow: 8px 8px 0px 0px #c9567a;\n  }\n\n  .text-outline {\n    -webkit-text-stroke: 1px #8b2244;\n    color: transparent;\n  }\n\n  /* Custom scrollbar for better brutalist look */\n  ::-webkit-scrollbar {\n    width: 10px;\n  }\n  ::-webkit-scrollbar-track {\n    background: #f5d0dc;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: #c9567a;\n  }\n</style>\n\n<div class=\"bg-[#f5d0dc] min-h-screen relative pb-32 overflow-hidden\" data-kid=\"1\">\n  \n  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/star-swirl.svg\" class=\"absolute top-20 -left-10 w-40 h-40 opacity-20 rotate-12\" style=\"filter: drop-shadow(0 0 0 #c9567a);\" decoding=\"async\" loading=\"lazy\" data-kid=\"2\">\n  \n  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/zigzag-hieroglyph.svg\" class=\"absolute top-[40%] -right-12 w-32 h-32 opacity-20 -rotate-45\" style=\"filter: drop-shadow(0 0 0 #c9567a);\" decoding=\"async\" loading=\"lazy\" data-kid=\"3\">\n\n  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/spotted-arrowhead.svg\" class=\"absolute bottom-40 -left-16 w-48 h-48 opacity-10\" style=\"filter: drop-shadow(0 0 0 #c9567a);\" decoding=\"async\" loading=\"lazy\" data-kid=\"4\">\n\n  \n  <div class=\"pt-12 px-6 mb-12 relative z-10\" data-kid=\"5\">\n    <div class=\"flex flex-col gap-0\" data-kid=\"6\">\n      <h1 class=\"text-5xl font-black uppercase text-outline leading-none tracking-tighter\" data-kid=\"7\">Register</h1>\n      <h1 class=\"text-5xl font-black uppercase text-outline leading-none tracking-tighter opacity-60\" data-kid=\"8\">Register</h1>\n      <h1 class=\"text-5xl font-black uppercase text-[#8b2244] leading-none tracking-tighter\" data-kid=\"9\">Register</h1>\n    </div>\n    <div class=\"w-24 h-3 bg-[#c9567a] mt-4\" data-kid=\"10\"></div>\n  </div>\n\n  \n  <form class=\"px-6 space-y-12 relative z-10\" data-kid=\"11\">\n    \n    \n    <div class=\"relative ml-4 mr-0 group\" data-kid=\"12\">\n      <div class=\"absolute -top-4 -left-2 bg-[#8b2244] px-3 py-1 z-20 border-2 border-[#5a1a30]\" data-kid=\"13\">\n        <label class=\"text-white text-xs font-black uppercase tracking-widest\" data-kid=\"14\">Responsible Name</label>\n      </div>\n      <div class=\"bg-[#fdf0f4] border-3 border-[#c9567a] p-5 hard-shadow transition-transform hover:-translate-x-1 hover:-translate-y-1 active:translate-x-1 active:translate-y-1\" data-kid=\"15\">\n        <input type=\"text\" placeholder=\"ENTER NAME...\" class=\"w-full bg-transparent border-none outline-hidden text-[#5a1a30] font-black uppercase placeholder:text-[#c9849a]/50 text-lg\" data-kid=\"16\">\n      </div>\n    </div>\n\n    \n    <div class=\"relative mr-4 ml-0\" data-kid=\"17\">\n      <div class=\"absolute -top-4 -right-2 bg-[#8b2244] px-3 py-1 z-20 border-2 border-[#5a1a30]\" data-kid=\"18\">\n        <label class=\"text-white text-xs font-black uppercase tracking-widest\" data-kid=\"19\">Email Address</label>\n      </div>\n      <div class=\"bg-[#fdf0f4] border-3 border-[#c9567a] p-5 hard-shadow\" data-kid=\"20\">\n        <input type=\"email\" placeholder=\"EMAIL@SYSTEM.COM\" class=\"w-full bg-transparent border-none outline-hidden text-[#5a1a30] font-black uppercase placeholder:text-[#c9849a]/50 text-lg\" data-kid=\"21\">\n      </div>\n    </div>\n\n    \n    <div class=\"relative ml-6 mr-2\" data-kid=\"22\">\n      <div class=\"absolute -top-4 -left-4 bg-[#c9567a] px-3 py-1 z-20 border-2 border-[#5a1a30]\" data-kid=\"23\">\n        <label class=\"text-white text-xs font-black uppercase tracking-widest\" data-kid=\"24\">Station Name</label>\n      </div>\n      <div class=\"bg-[#fdf0f4] border-3 border-[#c9567a] p-5 hard-shadow\" data-kid=\"25\">\n        <input type=\"text\" placeholder=\"STATION_ID_001\" class=\"w-full bg-transparent border-none outline-hidden text-[#5a1a30] font-black uppercase placeholder:text-[#c9849a]/50 text-lg\" data-kid=\"26\">\n      </div>\n    </div>\n\n    \n    <div class=\"relative ml-2 mr-6\" data-kid=\"27\">\n      <div class=\"absolute -top-4 -right-4 bg-[#8b2244] px-3 py-1 z-20 border-2 border-[#5a1a30]\" data-kid=\"28\">\n        <label class=\"text-white text-xs font-black uppercase tracking-widest\" data-kid=\"29\">Password</label>\n      </div>\n      <div class=\"bg-[#fdf0f4] border-3 border-[#c9567a] p-5 hard-shadow\" data-kid=\"30\">\n        <input type=\"password\" placeholder=\"********\" class=\"w-full bg-transparent border-none outline-hidden text-[#5a1a30] font-black uppercase placeholder:text-[#c9849a]/50 text-lg\" data-kid=\"31\">\n      </div>\n    </div>\n\n    \n    <div class=\"relative mx-4\" data-kid=\"32\">\n      <div class=\"absolute -top-4 left-1/2 -translate-x-1/2 bg-[#8b2244] px-3 py-1 z-20 border-2 border-[#5a1a30] whitespace-nowrap\" data-kid=\"33\">\n        <label class=\"text-white text-xs font-black uppercase tracking-widest\" data-kid=\"34\">Confirm Password</label>\n      </div>\n      <div class=\"bg-[#fdf0f4] border-3 border-[#c9567a] p-5 hard-shadow\" data-kid=\"35\">\n        <input type=\"password\" placeholder=\"********\" class=\"w-full bg-transparent border-none outline-hidden text-[#5a1a30] font-black uppercase placeholder:text-[#c9849a]/50 text-lg\" data-kid=\"36\">\n      </div>\n    </div>\n\n  </form>\n\n  \n  <div class=\"fixed bottom-0 left-0 w-full z-30\" data-kid=\"37\">\n    <button type=\"submit\" class=\"w-full bg-[#8b2244] text-white py-8 border-t-4 border-[#c9567a] flex items-center justify-between px-8 transition-colors hover:bg-[#5a1a30] active:pt-10 active:pb-6\" data-kid=\"38\">\n      <div class=\"flex items-center gap-2\" data-kid=\"39\">\n        <i class=\"ti ti-arrow-right text-3xl opacity-50\" data-kid=\"40\"></i>\n        <i class=\"ti ti-arrow-right text-3xl opacity-80\" data-kid=\"41\"></i>\n        <i class=\"ti ti-arrow-right text-3xl\" data-kid=\"42\"></i>\n      </div>\n      <span class=\"text-4xl font-black uppercase tracking-tighter\" data-kid=\"43\">Save</span>\n      <div class=\"flex items-center gap-2 rotate-180\" data-kid=\"44\">\n        <i class=\"ti ti-arrow-right text-3xl opacity-50\" data-kid=\"45\"></i>\n        <i class=\"ti ti-arrow-right text-3xl opacity-80\" data-kid=\"46\"></i>\n        <i class=\"ti ti-arrow-right text-3xl\" data-kid=\"47\"></i>\n      </div>\n    </button>\n  </div>\n</div>",
