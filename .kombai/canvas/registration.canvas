      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600;700&family=JetBrains+Mono&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-serif-ledger {\n    font-family: 'Crimson Pro', serif;\n  }\n  \n  .font-mono-ledger {\n    font-family: 'JetBrains Mono', monospace;\n  }\n\n  .paper-texture {\n    background-image: url('https://images.unsplash.com/photo-1601662528567-526cd06f6582?auto=format&w=800&q=80&fit=crop');\n    background-size: cover;\n    mix-blend-mode: multiply;\n  }\n\n  /* Hard shadow utility */\n  .hard-shadow {\n    box-shadow: 6px 6px 0px 0px #c9567a;\n  }\n\n  .button-shadow {\n    box-shadow: 4px 4px 0px 0px #8b2244;\n  }\n\n  .button-shadow:active {\n    box-shadow: 0px 0px 0px 0px #8b2244;\n    transform: translate(4px, 4px);\n  }\n</style>\n\n<div class=\"min-h-screen bg-[#f5d0dc] p-6 flex items-center justify-center font-sans\" data-kid=\"1\">\n  \n  <div class=\"relative w-full max-w-sm bg-white border-4 border-[#c9567a] hard-shadow overflow-hidden\" data-kid=\"2\">\n    \n    \n    <div class=\"absolute inset-0 paper-texture opacity-15 pointer-events-none\" data-kid=\"3\"></div>\n\n    \n    <div class=\"relative z-10 p-6 border-b-4 border-[#c9567a]\" data-kid=\"4\">\n      <div class=\"flex justify-between items-start mb-2\" data-kid=\"5\">\n        <div class=\"space-y-1\" data-kid=\"6\">\n          <p class=\"text-[10px] font-mono-ledger tracking-[0.2em] text-[#c9567a] uppercase\" data-kid=\"7\">Form Ref. STN-2024</p>\n          <h1 class=\"text-2xl font-serif-ledger font-bold tracking-tight text-[#8b2244] uppercase leading-none\" data-kid=\"8\">\n            New Station Record\n          </h1>\n        </div>\n        <i class=\"ti ti-ticket text-3xl text-[#c9567a]\" data-kid=\"9\"></i>\n      </div>\n      <div class=\"h-1 bg-[#c9567a] mt-4 opacity-30\" data-kid=\"10\"></div>\n    </div>\n\n    \n    <form class=\"relative z-10 flex flex-col\" data-kid=\"11\">\n      \n      <div class=\"flex border-b-2 border-[#c9567a] group\" data-kid=\"12\">\n        <label class=\"w-[35%] p-4 border-r-2 border-[#c9567a] bg-[#fdf0f4] flex items-center\" data-kid=\"13\">\n          <span class=\"text-[11px] font-serif-ledger font-bold tracking-widest text-[#8b2244] uppercase leading-tight\" data-kid=\"14\">\n            Responsible Name\n          </span>\n        </label>\n        <div class=\"flex-1\" data-kid=\"15\">\n          <input type=\"text\" placeholder=\"ENTER FULL NAME\" class=\"w-full h-full p-4 bg-transparent outline-hidden font-mono-ledger text-sm text-[#5a1a30] placeholder:text-[#c9849a] uppercase\" data-kid=\"16\">\n        </div>\n      </div>\n\n      \n      <div class=\"flex border-b-2 border-[#c9567a] group\" data-kid=\"17\">\n        <label class=\"w-[35%] p-4 border-r-2 border-[#c9567a] bg-[#fdf0f4] flex items-center\" data-kid=\"18\">\n          <span class=\"text-[11px] font-serif-ledger font-bold tracking-widest text-[#8b2244] uppercase leading-tight\" data-kid=\"19\">\n            Electronic Mail\n          </span>\n        </label>\n        <div class=\"flex-1\" data-kid=\"20\">\n          <input type=\"email\" placeholder=\"USER@STATION.COM\" class=\"w-full h-full p-4 bg-transparent outline-hidden font-mono-ledger text-sm text-[#5a1a30] placeholder:text-[#c9849a] uppercase\" data-kid=\"21\">\n        </div>\n      </div>\n\n      \n      <div class=\"flex border-b-2 border-[#c9567a] group\" data-kid=\"22\">\n        <label class=\"w-[35%] p-4 border-r-2 border-[#c9567a] bg-[#fdf0f4] flex items-center\" data-kid=\"23\">\n          <span class=\"text-[11px] font-serif-ledger font-bold tracking-widest text-[#8b2244] uppercase leading-tight\" data-kid=\"24\">\n            Station Designation\n          </span>\n        </label>\n        <div class=\"flex-1\" data-kid=\"25\">\n          <input type=\"text\" placeholder=\"ALPHA-01\" class=\"w-full h-full p-4 bg-[#f5d0dc]/20 outline-hidden font-mono-ledger text-sm text-[#5a1a30] placeholder:text-[#c9849a] uppercase\" data-kid=\"26\">\n        </div>\n      </div>\n\n      \n      <div class=\"flex border-b-2 border-[#c9567a] group\" data-kid=\"27\">\n        <label class=\"w-[35%] p-4 border-r-2 border-[#c9567a] bg-[#fdf0f4] flex items-center\" data-kid=\"28\">\n          <span class=\"text-[11px] font-serif-ledger font-bold tracking-widest text-[#8b2244] uppercase leading-tight\" data-kid=\"29\">\n            Secret Key\n          </span>\n        </label>\n        <div class=\"flex-1\" data-kid=\"30\">\n          <input type=\"password\" placeholder=\"••••••••\" class=\"w-full h-full p-4 bg-transparent outline-hidden font-mono-ledger text-sm text-[#5a1a30] placeholder:text-[#c9849a]\" data-kid=\"31\">\n        </div>\n      </div>\n\n      \n      <div class=\"flex border-b-4 border-[#c9567a] group\" data-kid=\"32\">\n        <label class=\"w-[35%] p-4 border-r-2 border-[#c9567a] bg-[#fdf0f4] flex items-center\" data-kid=\"33\">\n          <span class=\"text-[11px] font-serif-ledger font-bold tracking-widest text-[#8b2244] uppercase leading-tight\" data-kid=\"34\">\n            Verify Key\n          </span>\n        </label>\n        <div class=\"flex-1\" data-kid=\"35\">\n          <input type=\"password\" placeholder=\"••••••••\" class=\"w-full h-full p-4 bg-transparent outline-hidden font-mono-ledger text-sm text-[#5a1a30] placeholder:text-[#c9849a]\" data-kid=\"36\">\n        </div>\n      </div>\n\n      \n      <div class=\"p-6 bg-[#fdf0f4] flex flex-col items-end gap-6 relative\" data-kid=\"37\">\n        <div class=\"absolute left-6 top-8 opacity-20 transform -rotate-12 pointer-events-none\" data-kid=\"38\">\n          <i class=\"ti ti-rubber-stamp text-6xl text-[#8b2244]\" data-kid=\"39\"></i>\n        </div>\n\n        <button type=\"submit\" class=\"relative group z-10 w-full sm:w-auto bg-[#c9567a] border-2 border-[#8b2244] py-3 px-8 text-white font-bold tracking-[0.2em] uppercase transition-all button-shadow flex items-center justify-center gap-3\" data-kid=\"40\">\n          Commit Record\n          <i class=\"ti ti-device-floppy text-xl\" data-kid=\"41\"></i>\n        </button>\n        \n        <div class=\"w-full flex justify-between items-center opacity-40\" data-kid=\"42\">\n           <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/black-bar.svg\" class=\"h-8 w-24\" style=\"filter: invert(18%) sepia(35%) saturate(3419%) hue-rotate(320deg) brightness(91%) contrast(92%);\" alt=\"Barcode decoration\" data-kid=\"43\">\n           <span class=\"text-[9px] font-mono-ledger tracking-tighter\" data-kid=\"44\">AUTHENTICITY GUARANTEED // PPDM-01</span>\n        </div>\n      </div>\n    </form>\n    \n    \n    <div class=\"h-2 bg-[#8b2244]\" data-kid=\"45\"></div>\n  </div>\n</div>",
