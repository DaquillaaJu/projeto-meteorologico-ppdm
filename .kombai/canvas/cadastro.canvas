      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    margin: 0;\n    font-family: 'Inter', sans-serif;\n    background-color: #ffffff;\n    color: #8b2244;\n    overflow-x: hidden;\n  }\n\n  .grid-container {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    grid-template-rows: repeat(8, minmax(80px, auto));\n    width: 100%;\n    min-height: 100vh;\n    position: relative;\n  }\n\n  /* Grid Lines */\n  .grid-lines {\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    z-index: 50;\n  }\n  .line-v { width: 1px; height: 100%; background: #c9567a; position: absolute; top: 0; }\n  .line-h { height: 1px; width: 100%; background: #c9567a; position: absolute; left: 0; }\n\n  /* Halftone Texture Overlay */\n  .halftone {\n    position: absolute;\n    inset: 0;\n    background-image: url('https://images.unsplash.com/photo-1561714813-4f3b8e4c7f77?auto=format&w=600&q=80&fit=crop');\n    background-size: cover;\n    opacity: 0.15;\n    mix-blend-mode: multiply;\n    pointer-events: none;\n  }\n\n  .input-block {\n    background-color: #f5d0dc;\n    position: relative;\n    border: none;\n    transition: all 0.2s ease;\n  }\n  .input-block:focus-within {\n    background-color: #ffffff;\n    box-shadow: inset 0 0 0 2px #8b2244;\n  }\n\n  .btn-salvar {\n    background-color: #8b2244;\n    color: #ffffff;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    transition: all 0.2s ease;\n  }\n  .btn-salvar:hover {\n    background-color: #c9567a;\n  }\n  .btn-salvar:active {\n    transform: scale(0.98);\n  }\n</style>\n\n<div class=\"grid-container\" data-kid=\"1\">\n  \n  <div class=\"grid-lines\" data-kid=\"2\">\n    <div class=\"line-v\" style=\"left: 25%;\" data-kid=\"3\"></div>\n    <div class=\"line-v\" style=\"left: 50%;\" data-kid=\"4\"></div>\n    <div class=\"line-v\" style=\"left: 75%;\" data-kid=\"5\"></div>\n    <div class=\"line-h\" style=\"top: 12.5%;\" data-kid=\"6\"></div>\n    <div class=\"line-h\" style=\"top: 25%;\" data-kid=\"7\"></div>\n    <div class=\"line-h\" style=\"top: 37.5%;\" data-kid=\"8\"></div>\n    <div class=\"line-h\" style=\"top: 50%;\" data-kid=\"9\"></div>\n    <div class=\"line-h\" style=\"top: 62.5%;\" data-kid=\"10\"></div>\n    <div class=\"line-h\" style=\"top: 75%;\" data-kid=\"11\"></div>\n    <div class=\"line-h\" style=\"top: 87.5%;\" data-kid=\"12\"></div>\n  </div>\n\n  \n  <div class=\"col-span-3 row-span-1 bg-[#8b2244] p-6 flex flex-col justify-end relative overflow-hidden\" data-kid=\"13\">\n    <h1 class=\"text-white text-4xl font-black leading-none m-0 tracking-tighter uppercase z-10\" data-kid=\"14\">\n      Cadastrar<br data-kid=\"15\">Estação\n    </h1>\n    <div class=\"absolute -right-4 -bottom-2 text-white/10 text-8xl font-black pointer-events-none\" data-kid=\"16\">REG</div>\n  </div>\n  <div class=\"col-span-1 row-span-1 border-b border-[#c9567a] flex items-center justify-center\" data-kid=\"17\">\n    <i class=\"ti ti-layers-union text-4xl text-[#c9567a]\" data-kid=\"18\"></i>\n  </div>\n\n  \n  <div class=\"col-span-4 row-span-1 input-block group\" data-kid=\"19\">\n    <div class=\"halftone\" data-kid=\"20\"></div>\n    <label class=\"absolute top-2 left-3 text-[10px] font-bold uppercase tracking-widest text-[#8b2244] z-10\" data-kid=\"21\">Nome do Responsável</label>\n    <input type=\"text\" placeholder=\"JOÃO SILVA\" class=\"w-full h-full pt-8 pb-2 px-3 bg-transparent border-none outline-hidden text-xl font-black text-[#8b2244] placeholder:text-[#c9567a]/50 uppercase\" data-kid=\"22\">\n  </div>\n\n  \n  <div class=\"col-span-2 row-span-1 input-block border-r border-[#c9567a]\" data-kid=\"23\">\n    <div class=\"halftone\" data-kid=\"24\"></div>\n    <label class=\"absolute top-2 left-3 text-[10px] font-bold uppercase tracking-widest text-[#8b2244] z-10\" data-kid=\"25\">Email</label>\n    <input type=\"email\" placeholder=\"JOAO@EMAIL.COM\" class=\"w-full h-full pt-8 pb-2 px-3 bg-transparent border-none outline-hidden text-lg font-black text-[#8b2244] placeholder:text-[#c9567a]/50 uppercase\" data-kid=\"26\">\n  </div>\n  <div class=\"col-span-2 row-span-1 input-block\" data-kid=\"27\">\n    <div class=\"halftone\" data-kid=\"28\"></div>\n    <label class=\"absolute top-2 left-3 text-[10px] font-bold uppercase tracking-widest text-[#8b2244] z-10\" data-kid=\"29\">Nome da Estação</label>\n    <input type=\"text\" placeholder=\"ESTAÇÃO SUL\" class=\"w-full h-full pt-8 pb-2 px-3 bg-transparent border-none outline-hidden text-lg font-black text-[#8b2244] placeholder:text-[#c9567a]/50 uppercase\" data-kid=\"30\">\n  </div>\n\n  \n  <div class=\"col-span-2 row-span-1 input-block border-r border-[#c9567a]\" data-kid=\"31\">\n    <div class=\"halftone\" data-kid=\"32\"></div>\n    <label class=\"absolute top-2 left-3 text-[10px] font-bold uppercase tracking-widest text-[#8b2244] z-10\" data-kid=\"33\">Senha</label>\n    <input type=\"password\" placeholder=\"******\" class=\"w-full h-full pt-8 pb-2 px-3 bg-transparent border-none outline-hidden text-lg font-black text-[#8b2244] placeholder:text-[#c9567a]/50\" data-kid=\"34\">\n  </div>\n  <div class=\"col-span-2 row-span-1 input-block\" data-kid=\"35\">\n    <div class=\"halftone\" data-kid=\"36\"></div>\n    <label class=\"absolute top-2 left-3 text-[10px] font-bold uppercase tracking-widest text-[#8b2244] z-10\" data-kid=\"37\">Confirme Senha</label>\n    <input type=\"password\" placeholder=\"******\" class=\"w-full h-full pt-8 pb-2 px-3 bg-transparent border-none outline-hidden text-lg font-black text-[#8b2244] placeholder:text-[#c9567a]/50\" data-kid=\"38\">\n  </div>\n\n  \n  <div class=\"col-span-2 row-span-2 flex items-center justify-center p-8 bg-[#ffffff] relative\" data-kid=\"39\">\n     <div class=\"w-full h-full border-2 border-dashed border-[#c9567a] opacity-30\" data-kid=\"40\"></div>\n     <div class=\"absolute text-[8px] uppercase tracking-tighter text-[#c9567a] rotate-90 right-0\" data-kid=\"41\">ESTATION_MGMT_v1.0</div>\n  </div>\n  <div class=\"col-span-2 row-span-1 bg-[#f5d0dc]/20 flex items-center justify-center\" data-kid=\"42\">\n    <div class=\"w-4 h-4 rounded-full bg-[#8b2244] animate-pulse\" data-kid=\"43\"></div>\n  </div>\n  <div class=\"col-span-1 row-span-1 border-t border-[#c9567a]\" data-kid=\"44\"></div>\n\n  \n  <div class=\"col-span-2 row-span-1 flex items-center justify-center\" data-kid=\"45\">\n    <button class=\"text-[10px] font-bold uppercase tracking-widest text-[#c9567a] border-none bg-transparent cursor-pointer hover:text-[#8b2244]\" data-kid=\"46\">Cancelar</button>\n  </div>\n  <div class=\"col-span-2 row-span-1 btn-salvar group\" data-kid=\"47\">\n    <span class=\"text-2xl font-black uppercase tracking-widest mr-4\" data-kid=\"48\">Salvar</span>\n    <i class=\"ti ti-arrow-right text-3xl group-hover:translate-x-2 transition-transform\" data-kid=\"49\"></i>\n  </div>\n</div>",
