      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@700;800&family=Courier+Prime:wght@400;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-sans { font-family: 'Inter', sans-serif; }\n  .font-mono { font-family: 'Courier Prime', monospace; }\n  \n  .neo-shadow {\n    box-shadow: 8px 8px 0px 0px #8B2244;\n  }\n  \n  .btn-shadow {\n    box-shadow: 4px 4px 0px 0px #8B2244;\n  }\n  \n  .btn-active:active {\n    transform: translate(2px, 2px);\n    box-shadow: 2px 2px 0px 0px #8B2244;\n  }\n\n  /* Decorative pattern */\n  .bg-pattern {\n    background-color: #f5d0dc;\n    background-image:  linear-gradient(#8b2244 1px, transparent 1px), linear-gradient(90deg, #8b2244 1px, transparent 1px);\n    background-size: 20px 20px;\n    background-position: center center;\n    opacity: 0.05;\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n  }\n</style>\n\n<div class=\"min-h-screen bg-[#f5d0dc] relative flex flex-col font-sans text-[#8B2244] selection:bg-[#c9567a] selection:text-white\" data-kid=\"1\">\n  \n  <div class=\"bg-pattern\" data-kid=\"2\"></div>\n\n  \n  <header class=\"bg-[#ffffff] border-b-4 border-[#8B2244] px-6 py-8 relative z-10 flex justify-between items-center\" data-kid=\"3\">\n    <h1 class=\"text-3xl font-extrabold uppercase tracking-tighter leading-none\" data-kid=\"4\">\n      NOVA<br data-kid=\"5\">ESTAÇÃO\n    </h1>\n    <div class=\"bg-[#c9567a] border-3 border-[#8B2244] p-2 flex items-center justify-center\" data-kid=\"6\">\n      <i class=\"ti ti-radio text-white text-3xl\" data-kid=\"7\"></i>\n    </div>\n  </header>\n\n  \n  <main class=\"flex-1 p-5 relative z-10\" data-kid=\"8\">\n    <div class=\"bg-white border-3 border-[#8B2244] p-6 neo-shadow\" data-kid=\"9\">\n      \n      <form class=\"space-y-5\" onsubmit=\"event.preventDefault()\" data-kid=\"10\">\n        \n        \n        <div class=\"space-y-1\" data-kid=\"11\">\n          <label class=\"font-mono text-[10px] font-bold uppercase tracking-widest border-b border-[#8B2244]/20 pb-1 flex justify-between\" data-kid=\"12\">\n            <span data-kid=\"13\">Responsável</span>\n            <i class=\"ti ti-user text-xs\" data-kid=\"14\"></i>\n          </label>\n          <input type=\"text\" placeholder=\"EX: JOÃO DA SILVA\" class=\"w-full bg-transparent border-2 border-[#8B2244] p-3 text-sm font-bold placeholder-[#c9849a] focus:bg-[#fdf0f4] focus:border-[3px] outline-hidden transition-all\" data-kid=\"15\">\n        </div>\n\n        \n        <div class=\"space-y-1\" data-kid=\"16\">\n          <label class=\"font-mono text-[10px] font-bold uppercase tracking-widest border-b border-[#8B2244]/20 pb-1 flex justify-between\" data-kid=\"17\">\n            <span data-kid=\"18\">E-mail Corporativo</span>\n            <i class=\"ti ti-mail text-xs\" data-kid=\"19\"></i>\n          </label>\n          <input type=\"email\" placeholder=\"CONTATO@ESTACAO.COM\" class=\"w-full bg-transparent border-2 border-[#8B2244] p-3 text-sm font-bold placeholder-[#c9849a] focus:bg-[#fdf0f4] focus:border-[3px] outline-hidden transition-all\" data-kid=\"20\">\n        </div>\n\n        \n        <div class=\"space-y-1\" data-kid=\"21\">\n          <label class=\"font-mono text-[10px] font-bold uppercase tracking-widest border-b border-[#8B2244]/20 pb-1 flex justify-between\" data-kid=\"22\">\n            <span data-kid=\"23\">Identificador da Estação</span>\n            <i class=\"ti ti-building text-xs\" data-kid=\"24\"></i>\n          </label>\n          <input type=\"text\" placeholder=\"EX: CENTRAL-OESTE-01\" class=\"w-full bg-transparent border-2 border-[#8B2244] p-3 text-sm font-bold placeholder-[#c9849a] focus:bg-[#fdf0f4] focus:border-[3px] outline-hidden transition-all\" data-kid=\"25\">\n        </div>\n\n        \n        <div class=\"space-y-1\" data-kid=\"26\">\n          <label class=\"font-mono text-[10px] font-bold uppercase tracking-widest border-b border-[#8B2244]/20 pb-1 flex justify-between\" data-kid=\"27\">\n            <span data-kid=\"28\">Senha</span>\n            <i class=\"ti ti-lock text-xs\" data-kid=\"29\"></i>\n          </label>\n          <input type=\"password\" placeholder=\"••••••••\" class=\"w-full bg-transparent border-2 border-[#8B2244] p-3 text-sm font-bold placeholder-[#c9849a] focus:bg-[#fdf0f4] focus:border-[3px] outline-hidden transition-all\" data-kid=\"30\">\n        </div>\n\n        \n        <div class=\"space-y-1\" data-kid=\"31\">\n          <label class=\"font-mono text-[10px] font-bold uppercase tracking-widest border-b border-[#8B2244]/20 pb-1 flex justify-between\" data-kid=\"32\">\n            <span data-kid=\"33\">Confirmação</span>\n            <i class=\"ti ti-shield-check text-xs\" data-kid=\"34\"></i>\n          </label>\n          <input type=\"password\" placeholder=\"••••••••\" class=\"w-full bg-transparent border-2 border-[#8B2244] p-3 text-sm font-bold placeholder-[#c9849a] focus:bg-[#fdf0f4] focus:border-[3px] outline-hidden transition-all\" data-kid=\"35\">\n        </div>\n\n        \n        <div class=\"pt-4\" data-kid=\"36\">\n          <button class=\"w-full bg-[#c9567a] text-white border-3 border-[#8B2244] py-4 text-lg font-extrabold uppercase tracking-widest flex items-center justify-center gap-3 btn-shadow btn-active cursor-pointer transition-all\" data-kid=\"37\">\n            <span data-kid=\"38\">SALVAR</span>\n            <i class=\"ti ti-check text-xl\" data-kid=\"39\"></i>\n          </button>\n        </div>\n\n      </form>\n    </div>\n    \n    \n    <div class=\"mt-8 text-center opacity-40 font-mono text-[10px] uppercase tracking-widest\" data-kid=\"40\">\n      <p data-kid=\"41\">Terminal v1.0 // Protocolo Registro</p>\n    </div>\n  </main>\n</div>",
