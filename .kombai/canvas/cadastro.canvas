      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Courier+Prime:wght@400;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-mono {\n    font-family: 'Courier Prime', 'Courier New', Courier, monospace;\n  }\n\n  .ticket-edge {\n    clip-path: polygon(\n      0% 0%, 100% 0%, \n      100% calc(100% - 12px), 97.5% 100%, 95% calc(100% - 12px), 92.5% 100%, 90% calc(100% - 12px), 87.5% 100%, 85% calc(100% - 12px), 82.5% 100%, 80% calc(100% - 12px), 77.5% 100%, 75% calc(100% - 12px), 72.5% 100%, 70% calc(100% - 12px), 67.5% 100%, 65% calc(100% - 12px), 62.5% 100%, 60% calc(100% - 12px), 57.5% 100%, 55% calc(100% - 12px), 52.5% 100%, 50% calc(100% - 12px), 47.5% 100%, 45% calc(100% - 12px), 42.5% 100%, 40% calc(100% - 12px), 37.5% 100%, 35% calc(100% - 12px), 32.5% 100%, 30% calc(100% - 12px), 27.5% 100%, 25% calc(100% - 12px), 22.5% 100%, 20% calc(100% - 12px), 17.5% 100%, 15% calc(100% - 12px), 12.5% 100%, 10% calc(100% - 12px), 7.5% 100%, 5% calc(100% - 12px), 2.5% 100%, 0% calc(100% - 12px)\n    );\n  }\n\n  .dashed-divider {\n    border-top: 2px dashed #8b2244;\n    opacity: 0.3;\n  }\n</style>\n\n<div class=\"min-h-screen bg-[#c9567a] font-mono flex flex-col p-4\" data-kid=\"1\">\n  <div class=\"flex-1 flex flex-col bg-[#fdf0f4] shadow-2xl relative\" data-kid=\"2\">\n    \n    \n    <div class=\"bg-[#fdf0f4] p-6 pb-12 ticket-edge border-b-0\" data-kid=\"3\">\n      <div class=\"flex justify-between items-start\" data-kid=\"4\">\n        <div class=\"flex-1\" data-kid=\"5\">\n          <div class=\"flex items-center gap-2 mb-2\" data-kid=\"6\">\n            <i class=\"ti ti-terminal text-2xl text-[#8b2244]\" data-kid=\"7\"></i>\n            <span class=\"text-[10px] font-bold text-[#8b2244] tracking-tighter\" data-kid=\"8\">TERMINAL ACCESS</span>\n          </div>\n          <h1 class=\"text-xl font-bold text-[#8b2244] leading-tight mb-1\" data-kid=\"9\">REGISTRO DE ESTAÇÃO</h1>\n          <p class=\"text-xs text-[#8b2244]/60 font-bold tracking-widest\" data-kid=\"10\">// TICKET #001</p>\n        </div>\n        <div class=\"w-16 h-16 bg-white border border-[#8b2244] p-1 shadow-sm\" data-kid=\"11\">\n          <img src=\"https://images.pexels.com/photos/6250874/pexels-photo-6250874.jpeg?auto=compress&cs=tinysrgb&w=200&q=80\" alt=\"Barcode\" class=\"w-full h-full object-cover grayscale brightness-110 contrast-125\" decoding=\"async\" loading=\"lazy\" data-kid=\"12\">\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"flex-1 px-6 pb-24\" data-kid=\"13\">\n      <div class=\"space-y-6 mt-4\" data-kid=\"14\">\n        \n        \n        <div data-kid=\"15\">\n          <div class=\"flex items-baseline gap-4 py-3\" data-kid=\"16\">\n            <label class=\"w-28 text-[9px] font-bold text-[#8b2244] uppercase tracking-tighter\" data-kid=\"17\">RESPONSÁVEL</label>\n            <input type=\"text\" placeholder=\"NOME COMPLETO\" class=\"flex-1 bg-transparent border-b-3 border-[#8b2244] py-1 text-sm text-[#8b2244] placeholder:text-[#8b2244]/30 outline-none focus:bg-white/50 transition-colors\" data-kid=\"18\">\n          </div>\n          <div class=\"dashed-divider\" data-kid=\"19\"></div>\n        </div>\n\n        \n        <div data-kid=\"20\">\n          <div class=\"flex items-baseline gap-4 py-3\" data-kid=\"21\">\n            <label class=\"w-28 text-[9px] font-bold text-[#8b2244] uppercase tracking-tighter\" data-kid=\"22\">E-MAIL</label>\n            <input type=\"email\" placeholder=\"CONTATO@EMAIL.COM\" class=\"flex-1 bg-transparent border-b-3 border-[#8b2244] py-1 text-sm text-[#8b2244] placeholder:text-[#8b2244]/30 outline-none focus:bg-white/50 transition-colors\" data-kid=\"23\">\n          </div>\n          <div class=\"dashed-divider\" data-kid=\"24\"></div>\n        </div>\n\n        \n        <div data-kid=\"25\">\n          <div class=\"flex items-baseline gap-4 py-3\" data-kid=\"26\">\n            <label class=\"w-28 text-[9px] font-bold text-[#8b2244] uppercase tracking-tighter\" data-kid=\"27\">ESTAÇÃO</label>\n            <input type=\"text\" placeholder=\"IDENTIFICADOR\" class=\"flex-1 bg-transparent border-b-3 border-[#8b2244] py-1 text-sm text-[#8b2244] placeholder:text-[#8b2244]/30 outline-none focus:bg-white/50 transition-colors\" data-kid=\"28\">\n          </div>\n          <div class=\"dashed-divider\" data-kid=\"29\"></div>\n        </div>\n\n        \n        <div data-kid=\"30\">\n          <div class=\"flex items-baseline gap-4 py-3\" data-kid=\"31\">\n            <label class=\"w-28 text-[9px] font-bold text-[#8b2244] uppercase tracking-tighter\" data-kid=\"32\">SENHA</label>\n            <input type=\"password\" placeholder=\"********\" class=\"flex-1 bg-transparent border-b-3 border-[#8b2244] py-1 text-sm text-[#8b2244] placeholder:text-[#8b2244]/30 outline-none focus:bg-white/50 transition-colors\" data-kid=\"33\">\n          </div>\n          <div class=\"dashed-divider\" data-kid=\"34\"></div>\n        </div>\n\n        \n        <div data-kid=\"35\">\n          <div class=\"flex items-baseline gap-4 py-3\" data-kid=\"36\">\n            <label class=\"w-28 text-[9px] font-bold text-[#8b2244] uppercase tracking-tighter\" data-kid=\"37\">CONFIRMAÇÃO</label>\n            <input type=\"password\" placeholder=\"********\" class=\"flex-1 bg-transparent border-b-3 border-[#8b2244] py-1 text-sm text-[#8b2244] placeholder:text-[#8b2244]/30 outline-none focus:bg-white/50 transition-colors\" data-kid=\"38\">\n          </div>\n          <div class=\"dashed-divider\" data-kid=\"39\"></div>\n        </div>\n\n      </div>\n\n      \n      <div class=\"absolute bottom-20 left-0 -translate-x-1/2 w-4 h-4 bg-[#c9567a] rounded-full\" data-kid=\"40\"></div>\n      <div class=\"absolute bottom-20 right-0 translate-x-1/2 w-4 h-4 bg-[#c9567a] rounded-full\" data-kid=\"41\"></div>\n    </div>\n\n    \n    <div class=\"p-6 pt-0 bg-[#fdf0f4]\" data-kid=\"42\">\n      <button class=\"w-full bg-[#8b2244] border-4 border-[#c9567a] py-4 flex items-center justify-center gap-2 active:scale-98 transition-transform cursor-pointer\" data-kid=\"43\">\n        <span class=\"text-white font-bold tracking-widest text-sm\" data-kid=\"44\">>> SALVAR_DADOS</span>\n      </button>\n    </div>\n\n  </div>\n</div>",
